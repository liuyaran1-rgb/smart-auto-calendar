rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: schedules
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - date: string (required, YYYY-MM-DD)
    //   - time: string (optional, HH:mm)
    //   - memo: string (optional, < 1000 chars)
    //   - category: string (required, enum: work, personal, important, other)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidSchedule(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.category in ['work', 'personal', 'important', 'other'] &&
             data.uid == request.auth.uid &&
             (data.memo == null || (data.memo is string && data.memo.size() <= 1000));
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidSchedule(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidSchedule(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
